GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_REPO=your-org/your-repo
POLL_INTERVAL=300
CI_FAIL_THRESHOLD=60
CI_STUCK_THRESHOLD=45
STALE_DAYS=7
ANCIENT_DAYS=14
QUEUE_WARN_DEPTH=5
# Set to true to post a GitHub comment on first detection of error-severity issues
# Requires pull_requests:write scope on the token
POST_COMMENTS=false
OUTPUT_PATH=/data/watchdog.json
