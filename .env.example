# Required
GITHUB_TOKEN=ghp_...          # classic PAT: repo + read:org scopes
GITHUB_REPO=your-org/your-repo

# Optional — all have defaults
SITE_TITLE=AI Factory Status   # dashboard title
REFRESH_SECONDS=60             # page auto-refresh interval (seconds)
POLL_INTERVAL=300              # orchestrator + watchdog poll cadence (seconds)
MAX_PARALLEL_WOS=2             # max concurrent agent assignments
POST_COMMENTS=false            # set true to have watchdog post GitHub PR comments
WO_PATH=docs/project_management/work_orders
RUNS_PATH=docs/factory/runs
PLAN_PATH=docs/factory/PLAN.json
CI_FAIL_THRESHOLD=60           # minutes before a CI run is flagged as stuck
CI_STUCK_THRESHOLD=45          # minutes before a queued run is flagged
STALE_DAYS=7                   # days before a PR is marked stale
ANCIENT_DAYS=14                # days before a PR is marked ancient
QUEUE_WARN_DEPTH=5             # open PRs before watchdog raises a queue warning
DAILY_SUMMARY_HOUR=            # UTC hour to post daily summary issue (blank = off)
SUMMARY_ISSUE_NUMBER=          # GitHub issue number to post summaries on

# Optional: comma-separated additional repos for the orchestrator WO board.
SECONDARY_REPOS=

# ── Push Notifications ───────────────────────────────────────────────────────
#
# ntfy.sh — free push notifications to iOS / Android / desktop / browser.
#
#   Topic: auto-generated by `make agent-setup` (e.g. factory-a7k3m9q2x4b8nf).
#          14 random alphanumeric chars — effectively unguessable.
#          Manage via Settings → Authentication in the factory dashboard.
#          Anyone who knows the topic URL can subscribe — use the auto-generated
#          name, or point NTFY_SERVER at a self-hosted ntfy for full privacy.
#
#   To subscribe: install the ntfy app (https://ntfy.sh), add:
#     https://ntfy.sh/<your-topic>
#
#   Events that fire notifications:
#     - WO needs human review (high priority)
#     - Agent gave up / errored (high priority)
#     - WO merged / complete (default priority)
#     - Dependabot PR merged (low priority)
#     - Dependabot conflict auto-rebased (low priority)
#
NTFY_TOPIC=                # set by agent-setup; or paste from Settings → Authentication
NTFY_SERVER=https://ntfy.sh  # override to self-host: http://localhost:8098

# Slack — fires same events as ntfy in parallel (optional)
SLACK_WEBHOOK_URL=

# Slack two-way bot (Socket Mode) — lets you chat with the PM from Slack
# Setup: api.slack.com/apps → your app → Socket Mode (enable) → App-Level Token (connections:write)
#        Event Subscriptions → app_mention + message.im
#        OAuth & Permissions → chat:write, app_mentions:read, im:history, reactions:write
SLACK_BOT_TOKEN=    # xoxb-...  (Bot User OAuth Token)
SLACK_APP_TOKEN=    # xapp-...  (App-Level Token for Socket Mode)

# Codex GitHub Actions dispatch (WO-367)
CODEX_WORKFLOW_FILE=codex-dispatch.yml

# ── Agent Runner — subscription-based, no API keys required ──────────────────
#
# All four backends use CLI tools that authenticate via your existing subscription.
# No pay-per-use API billing. One-time CLI install + auth per backend.
#
# Claude  — Install: curl -fsSL https://claude.ai/install.sh | bash
#            Auth:   claude login  (Claude Pro / Max subscription)
#
# Cursor  — Install: curl https://cursor.com/install -fsS | bash
#            Auth:   CURSOR_API_KEY below  (Cursor Pro subscription)
#
# Codex   — Install: npm install -g @openai/codex
#            Auth:   codex login  (ChatGPT Plus / Pro subscription)
#
# Gemini  — Install: npm install -g @google/gemini-cli
#            Auth:   run `gemini` once to complete Google OAuth  (Gemini Advanced subscription)
#
PREFERRED_AGENT=claude       # claude | cursor | codex | gemini
AGENT_NAME=claude-runner     # display name shown on factory dashboard
CURSOR_API_KEY=              # only needed if PREFERRED_AGENT=cursor
AGENT_TIMEOUT=7200           # max seconds per WO before runner gives up (2 hours)

# ── Peer review chain — which CLI each reviewer uses ─────────────────────────
#
# All four reviewers default to claude (most reliable for text Q&A).
# Set to cursor/codex/gemini to use a different subscription for a reviewer.
# Each reviewer uses the ask() mode of its backend — read-only, no file edits:
#   claude  → `claude --print -p "question"`
#   cursor  → `agent --print --mode ask "question"`
#   codex   → `codex review "question"`
#   gemini  → `gemini --yolo -p "question"`  (--yolo required for autonomous execution)
#
SECURITY_REVIEWER_BACKEND=claude     # claude | cursor | codex | gemini
ARCH_REVIEWER_BACKEND=claude
CORRECTNESS_REVIEWER_BACKEND=claude
PERF_REVIEWER_BACKEND=claude
