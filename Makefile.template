# {{PROJECT_NAME}} — Makefile
# Copy to Makefile and fill in the {{...}} sections for your stack.
#
# The ci-local target MUST mirror the GitHub Actions PR gate exactly.
# Every agent runs `make ci-local` before opening a PR.
#
# If this project uses Docker Compose for local development, also fill in the
# Docker section below (build-svc, deploy-changed, verify-local, wait-healthy).
# These targets are what agents use to deploy code changes to the running local
# stack before verifying features — they are NOT needed for CD-based projects.

.PHONY: help install test lint build ci-local clean \
        build-svc deploy-changed verify-local wait-healthy

help:  ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
	  awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-22s\033[0m %s\n", $$1, $$2}'

